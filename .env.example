# ===========================================
# FORESTRY POTS — ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env.local for development

# -----------------------------
# DATABASE
# -----------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/forestry_pots?schema=public"

# -----------------------------
# AUTHENTICATION (NextAuth.js)
# -----------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-min-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------
# EMAIL (Resend)
# -----------------------------
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="Forestry <noreply@forestry.ae>"

# -----------------------------
# FILE STORAGE (Cloudinary)
# -----------------------------
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# -----------------------------
# APPLICATION
# -----------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Forestry"
ADMIN_EMAIL="admin@forestry.ae"

# -----------------------------
# INITIAL ADMIN SETUP (first run only)
# -----------------------------
ADMIN_SETUP_EMAIL="admin@forestry.ae"
ADMIN_SETUP_PASSWORD="ChangeThisPassword123!"
ADMIN_SETUP_NAME="System Admin"
