/**
 * Production Job Details Page
 * View job specifications and update production status
 */

'use client';

import { useState } from 'react';
import { useParams, useRouter } from 'next/navigation';
import StatusUpdater from '@/components/production/StatusUpdater';
import { ArrowLeft, FileText, Layers } from 'lucide-react';

// Dummy data
const DUMMY_JOB = {
  id: 'prod-001',
  orderNumber: 'PO-2026-0001',
  status: 'IN_PROGRESS',
  priority: 'NORMAL',
  currentStage: 'MOLDING',
  estimatedCompletion: new Date(Date.now() + 10 * 24 * 60 * 60 * 1000),
  managerApprovedAt: new Date(Date.now() - 3 * 24 * 60 * 60 * 1000),
  managerNotes: 'Standard production timeline. No rush items.',
  productionNotes: 'Molding process started on schedule. Using Kiln A.',
  quotation: {
    rfp: {
      vendorProfile: {
        companyName: 'Al Jazeera Ceramics',
        user: {
          email: 'contact@aljazeera.ae',
        },
      },
    },
    items: [
      {
        id: 'item-001',
        description: 'Large Terracotta Pot - Premium Grade',
        specifications:
          '{"size": "Large (24\\" height)", "color": "Terracotta", "texture": "Smooth", "finish": "Matte"}',
        quantity: 100,
        unitPrice: 45,
        totalPrice: 4500,
      },
      {
        id: 'item-002',
        description: 'Medium Decorative Pot - Hand-Painted',
        specifications:
          '{"size": "Medium (16\\" height)", "color": "Custom Blue", "texture": "Hammered", "finish": "Glossy"}',
        quantity: 150,
        unitPrice: 35,
        totalPrice: 5250,
      },
    ],
    total: 10530,
  },
  statusHistory: [
    {
      id: 'log-001',
      fromStage: 'PENDING',
      toStage: 'MOLDING',
      notes: 'Started molding process',
      updatedBy: 'Ahmad Al-Mansouri',
      updatedByRole: 'PRODUCTION',
      createdAt: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000),
    },
  ],
};

export default function JobDetailsPage() {
  const params = useParams();
  const router = useRouter();
  const jobId = params.id as string;
  const [job, setJob] = useState(DUMMY_JOB);
  const [isUpdating, setIsUpdating] = useState(false);

  const handleUpdateStatus = async (toStage: string, notes?: string) => {
    setIsUpdating(true);
    try {
      // Simulate API call
      await new Promise((resolve) => setTimeout(resolve, 1000));
      setJob((prev) => ({
        ...prev,
        currentStage: toStage,
        productionNotes: notes || prev.productionNotes,
        statusHistory: [
          {
            id: `log-${Date.now()}`,
            fromStage: prev.currentStage,
            toStage,
            notes: notes,
            updatedBy: 'Current User',
            updatedByRole: 'PRODUCTION',
            createdAt: new Date(),
          },
          ...prev.statusHistory,
        ],
      }));
    } catch (error) {
      console.error('Error updating status:', error);
    } finally {
      setIsUpdating(false);
    }
  };

  const totalQuantity = job.quotation.items.reduce((sum, item) => sum + item.quantity, 0);

  return (
    <div className="min-h-screen bg-gray-50">
      {/* Header */}
      <div className="bg-white border-b border-gray-200">
        <div className="max-w-6xl mx-auto px-6 py-6">
          <button
            onClick={() => router.back()}
            className="flex items-center gap-2 text-blue-600 hover:text-blue-700 font-semibold mb-4"
          >
            <ArrowLeft className="w-4 h-4" />
            Back to Jobs
          </button>
          <h1 className="text-3xl font-bold text-gray-900">{job.orderNumber}</h1>
          <p className="text-gray-600 mt-1">{job.quotation.rfp.vendorProfile.companyName}</p>
        </div>
      </div>

      {/* Main Content */}
      <div className="max-w-6xl mx-auto px-6 py-8">
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {/* Left: Job Details */}
          <div className="lg:col-span-2 space-y-6">
            {/* Order Summary */}
            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h2 className="text-lg font-bold text-gray-900 mb-4">Order Summary</h2>
              <div className="grid grid-cols-2 gap-4">
                <div className="bg-gray-50 rounded-lg p-4">
                  <p className="text-sm text-gray-600">Total Items</p>
                  <p className="text-2xl font-bold text-gray-900">{totalQuantity}</p>
                </div>
                <div className="bg-gray-50 rounded-lg p-4">
                  <p className="text-sm text-gray-600">Order Value</p>
                  <p className="text-2xl font-bold text-gray-900">AED {job.quotation.total.toLocaleString()}</p>
                </div>
                <div className="bg-gray-50 rounded-lg p-4">
                  <p className="text-sm text-gray-600">Est. Completion</p>
                  <p className="text-lg font-bold text-gray-900">
                    {job.estimatedCompletion.toLocaleDateString()}
                  </p>
                </div>
                <div className="bg-gray-50 rounded-lg p-4">
                  <p className="text-sm text-gray-600">Vendor Email</p>
                  <p className="text-sm font-semibold text-blue-600 break-all">
                    {job.quotation.rfp.vendorProfile.user.email}
                  </p>
                </div>
              </div>
            </div>

            {/* Pot Specifications */}
            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h2 className="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                <Layers className="w-5 h-5" />
                Product Specifications
              </h2>
              <div className="space-y-4">
                {job.quotation.items.map((item, idx) => {
                  const specs = JSON.parse(item.specifications || '{}');
                  return (
                    <div key={idx} className="border border-gray-200 rounded-lg p-4">
                      <h3 className="font-semibold text-gray-900 mb-3">{item.description}</h3>
                      <div className="grid grid-cols-2 gap-3 text-sm">
                        <div>
                          <p className="text-gray-600">Quantity</p>
                          <p className="font-semibold text-gray-900">{item.quantity} units</p>
                        </div>
                        {specs.size && (
                          <div>
                            <p className="text-gray-600">Size</p>
                            <p className="font-semibold text-gray-900">{specs.size}</p>
                          </div>
                        )}
                        {specs.color && (
                          <div>
                            <p className="text-gray-600">Color</p>
                            <p className="font-semibold text-gray-900">{specs.color}</p>
                          </div>
                        )}
                        {specs.texture && (
                          <div>
                            <p className="text-gray-600">Texture</p>
                            <p className="font-semibold text-gray-900">{specs.texture}</p>
                          </div>
                        )}
                        {specs.finish && (
                          <div>
                            <p className="text-gray-600">Finish</p>
                            <p className="font-semibold text-gray-900">{specs.finish}</p>
                          </div>
                        )}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>

            {/* Manager Notes */}
            {job.managerNotes && (
              <div className="bg-blue-50 border border-blue-200 rounded-lg p-6">
                <h3 className="font-bold text-blue-900 mb-2 flex items-center gap-2">
                  <FileText className="w-5 h-5" />
                  Manager Notes
                </h3>
                <p className="text-blue-800">{job.managerNotes}</p>
              </div>
            )}

            {/* Status History */}
            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h2 className="text-lg font-bold text-gray-900 mb-4">Production History</h2>
              <div className="space-y-3">
                {job.statusHistory.map((log, idx) => (
                  <div key={idx} className="flex gap-4 pb-4 border-b border-gray-200 last:border-b-0">
                    <div className="text-center min-w-fit">
                      <p className="text-xs text-gray-500">{new Date(log.createdAt).toLocaleDateString()}</p>
                      <p className="text-xs font-semibold text-gray-700">
                        {new Date(log.createdAt).toLocaleTimeString()}
                      </p>
                    </div>
                    <div className="flex-1">
                      <p className="text-sm font-semibold text-gray-900">
                        {log.fromStage} → {log.toStage}
                      </p>
                      {log.notes && <p className="text-sm text-gray-600 mt-1">{log.notes}</p>}
                      <p className="text-xs text-gray-500 mt-1">by {log.updatedBy}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Right: Status Updater */}
          <div className="lg:col-span-1">
            <StatusUpdater
              currentStage={job.currentStage}
              orderNumber={job.orderNumber}
              onUpdate={handleUpdateStatus}
              isLoading={isUpdating}
            />
          </div>
        </div>
      </div>
    </div>
  );
}
